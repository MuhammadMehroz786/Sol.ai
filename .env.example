# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# ─── n8n Webhooks ─────────────────────────────────────────────────────────────
# Base URL of your n8n instance. No trailing slash, no /webhook suffix.
# Example: https://your-n8n.app.n8n.cloud  or  https://n8n.yourdomain.com
VITE_N8N_BASE=https://your-n8n-instance.com

# ─── Optional ─────────────────────────────────────────────────────────────────
# Server-side proxy for AI provider health checks (avoids CORS & key exposure).
# Point to a Supabase Edge Function or n8n workflow that accepts:
#   { agent_id: string, endpoint: string }
# and returns:
#   { success: boolean, status_code: number }
# VITE_HEALTH_CHECK_PROXY=https://your-proxy.com/health-check
